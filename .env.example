# Salin file ini menjadi `.env` lalu sesuaikan nilainya.
# Variabel ini dipakai baik oleh aplikasi Next.js maupun podman-compose.yml.

# --- Database ---
POSTGRES_DB=sipus_db
POSTGRES_USER=sipus_user
POSTGRES_PASSWORD=sipus_pass
DB_PORT=5432

# Connection string lengkap yang dipakai Prisma & aplikasi.
# Saat dijalankan via podman-compose, host "db" merujuk ke container PostgreSQL.
# Saat development lokal (npm run dev) tanpa container app, gunakan "localhost".
DATABASE_URL="postgresql://sipus_user:sipus_pass@localhost:5432/sipus_db?schema=public"

# --- Aplikasi ---
APP_PORT=3000

# Secret untuk menandatangani JWT sesi login (src/lib/auth.ts).
# WAJIB diganti dengan string acak yang panjang sebelum production.
# Contoh membuatnya: openssl rand -base64 32
AUTH_SECRET=change_this_secret

# --- pgAdmin (opsional, profile "tools") ---
PGADMIN_EMAIL=admin@sipus.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
